{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=SaasStarter;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "PrivateKeyPem": "REPLACE_WITH_RSA_PRIVATE_KEY_PEM",
    "PublicKeyPem":  "REPLACE_WITH_RSA_PUBLIC_KEY_PEM",
    "Issuer": "SaaS System",
    "Audience": "https://localhost",
    "ExpiresInMinutes": 15,
    "RefreshTokenDays": 7
  },
  "EmailSettings": {
    "SmtpServer":   "smtp.gmail.com",
    "SmtpPort":     587,
    "SmtpUsername": "REPLACE_WITH_SMTP_USERNAME",
    "SmtpPassword": "REPLACE_WITH_SMTP_PASSWORD",
    "SenderName":   "SaaS Starter",
    "SenderEmail":  "REPLACE_WITH_SENDER_EMAIL"
  }
}
